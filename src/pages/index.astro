---
import BaseLayout from '../layouts/BaseLayout.astro';
import Grain from '../components/home/Grain.astro';
import Hero from '../components/home/Hero.astro';
import TrustedBy from '../components/home/TrustedBy.astro';
import WhatWeDo from '../components/home/WhatWeDo.astro';
import Compare from '../components/home/Compare.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import Roles from '../components/home/Roles.astro';
import Proof from '../components/home/Proof.astro';
import BehindEveryMatch from '../components/home/BehindEveryMatch.astro';
import Pricing from '../components/home/Pricing.astro';
import Team from '../components/home/Team.astro';
import Faq from '../components/home/Faq.astro';
import FinalCta from '../components/home/FinalCta.astro';
import Divider from '../components/home/Divider.astro';
---
<BaseLayout title="Hire sharper talent without hiring locally">
  <Grain />

  {/* Fold 1 — Hero + Trusted-by: one full-height (min 100vh) screen.
      No divider after the hero — its rounded bottom edge is the transition. */}
  <div class="fold1">
    <Hero />
    <TrustedBy />
  </div>

  {/* What we do / The Problem (scroll-ink statement). */}
  <WhatWeDo />
  <Divider />

  {/* Roles we hire for (opposed marquee tickers) — moved up, below The Problem. */}
  <Roles />
  <Divider />

  {/* How We Compare (comparison table). */}
  <Compare />
  <Divider />

  {/* How It Works (process steps + growing assessment bars). */}
  <HowItWorks />
  <Divider />

  {/* The Results / Proof (stats + testimonial accordion). */}
  <Proof />
  <Divider />

  {/* Behind Every Match (fan-out cards + hover-lift). */}
  <BehindEveryMatch />
  <Divider />

  {/* Pricing (billing widget + bento + clay CTA). */}
  <Pricing />
  <Divider />

  {/* The people behind it (team). */}
  <Team />
  <Divider />

  {/* FAQ. */}
  <Faq />
  <Divider />

  {/* Final CTA + testimonial (the site Footer follows, from BaseLayout).
      No divider after the final fold. */}
  <FinalCta />
</BaseLayout>

<style>
  .fold1{min-height:100vh; display:flex; flex-direction:column; background:var(--gb-paper)}
  @media (max-width:768px){
    .fold1{min-height:auto; display:block}
  }
</style>
