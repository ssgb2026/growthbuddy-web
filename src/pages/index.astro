---
import BaseLayout from '../layouts/BaseLayout.astro';
import Grain from '../components/home/Grain.astro';
import Hero from '../components/home/Hero.astro';
import TrustedBy from '../components/home/TrustedBy.astro';
import WhatWeDo from '../components/home/WhatWeDo.astro';
import Compare from '../components/home/Compare.astro';
---
<BaseLayout title="Hire sharper talent without hiring locally">
  <Grain />

  {/* Fold 1 — Hero + Trusted-by: one full-height (min 100vh) screen. */}
  <div class="fold1">
    <Hero />
    <TrustedBy />
  </div>

  {/* Fold 2 — What we do / The Problem (scroll-ink statement). */}
  <WhatWeDo />

  {/* Fold 3 — How We Compare (comparison table). */}
  <Compare />

  {/*
    Remaining homepage folds — built one at a time into src/components/home/:
      4  How It Works       8  Pricing
      5  Roles we hire for  9  Team & FAQ
      6  The Results        10 Final CTA & Footer
  */}
</BaseLayout>

<style>
  .fold1{min-height:100vh; display:flex; flex-direction:column; background:var(--gb-paper)}
  @media (max-width:768px){
    .fold1{min-height:auto; display:block}
  }
</style>
