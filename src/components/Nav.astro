---
const links = [
  { label: "How it works", href: "/how-it-works" },
  { label: "Pricing", href: "/pricing" },
  { label: "Roles", href: "/hire" },
  { label: "Industries", href: "/industries" },
  { label: "Resources", href: "/resources" },
];
---
<header style="border-bottom:1px solid var(--gb-hairline);">
  <nav class="container" aria-label="Primary" style="display:flex;align-items:center;justify-content:space-between;height:72px;gap:24px;">
    <a href="/" style="font-family:var(--gb-font-body);font-weight:600;font-size:18px;">Growthbuddy</a>
    <ul style="display:flex;gap:28px;list-style:none;font-size:15px;">
      {links.map((l) => (<li><a href={l.href}>{l.label}</a></li>))}
    </ul>
    <a href="/book-a-call" style="background:var(--gb-clay);color:var(--gb-paper);padding:10px 18px;border-radius:999px;font-size:15px;font-weight:500;">Book a call</a>
  </nav>
</header>
