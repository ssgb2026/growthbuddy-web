---
const year = new Date().getFullYear();
---
<footer style="border-top:1px solid var(--gb-hairline);margin-top:120px;">
  <div class="container" style="padding-block:48px;display:flex;flex-wrap:wrap;gap:40px;justify-content:space-between;">
    <div style="max-width:30ch;">
      <div style="font-weight:600;font-size:18px;">Growthbuddy</div>
      <p style="color:var(--gb-muted);font-size:15px;margin-top:12px;">Remote hiring for US companies, done properly — and looked after long after the hire.</p>
    </div>
    <nav aria-label="Footer" style="display:flex;gap:48px;font-size:15px;">
      <div><strong style="font-family:var(--gb-font-label);text-transform:uppercase;font-size:14px;color:var(--gb-clay);">Explore</strong>
        <ul style="list-style:none;margin-top:12px;display:grid;gap:8px;">
          <li><a href="/how-it-works">How it works</a></li><li><a href="/pricing">Pricing</a></li>
          <li><a href="/hire">Roles</a></li><li><a href="/industries">Industries</a></li>
        </ul></div>
      <div><strong style="font-family:var(--gb-font-label);text-transform:uppercase;font-size:14px;color:var(--gb-clay);">Company</strong>
        <ul style="list-style:none;margin-top:12px;display:grid;gap:8px;">
          <li><a href="/about">About</a></li><li><a href="/contact">Contact</a></li><li><a href="/book-a-call">Book a call</a></li>
        </ul></div>
    </nav>
  </div>
  <div class="container" style="border-top:1px solid var(--gb-hairline);padding-block:22px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-size:13px;color:var(--gb-muted);">
    <span>© {year} Growthbuddy. All rights reserved.</span>
    <span><a href="/privacy">Privacy</a> &nbsp;·&nbsp; <a href="/terms">Terms</a></span>
  </div>
</footer>
