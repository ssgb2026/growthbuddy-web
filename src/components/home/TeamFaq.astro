---
/*
  Fold 9 — Team & FAQ (reproduces "Fold 9 – Team & FAQ.html" / spec §7).
  Two [data-step] blocks (Team, FAQ). Each gets its OWN IntersectionObserver
  (threshold 0.3); on intersect the step's inner [data-anim] children animate to
  their final state staggered by each child's data-delay (ms), then unobserve.
  reduced-motion / no-IntersectionObserver → finalize immediately; <noscript>
  reveals everything; a visibility-aware fallback means it's never stuck hidden.

  Team: initials avatars (§B.14) — no AI faces; name --gb-weight-strong, role line
  Space Grotesk uppercase --gb-clay. FAQ: native <details>/<summary> with the first
  open by default; the "+" rotates to "×" via pure CSS (details[open] [data-ic]).
  Paper bg + global PNG grain; content-visibility:auto. Copy verbatim from the mock.
*/
const team = [
  { initial: 'A', name: 'Avani', role: 'Co-founder' },
  { initial: 'S', name: 'Srikant', role: 'Co-founder' },
  { initial: 'S', name: 'Srujana', role: 'Sales Strategy' },
  { initial: 'H', name: 'Harshita', role: 'Sales & Marketing Analyst' },
  { initial: 'A', name: 'Aditi', role: "Founder’s Associate" },
  { initial: 'C', name: 'Clessia', role: 'HR Coordinator' },
];
const faqs = [
  { q: 'Where do the team members work?', a: 'They work remotely, aligned to your business hours, so they’re online and reachable exactly when your team is. In practice, it’s identical to having someone in-house – they join your meetings, use your tools, and live in your Slack channels day to day.' },
  { q: 'Who employs them?', a: 'We do – every team member is officially employed by Growthbuddy and sits on our payroll. That means we take care of the contracts, taxes, and cross-border compliance behind the scenes, so you get a dedicated person without any of the legal or admin overhead landing on your desk.' },
  { q: 'How much does it cost?', a: 'It’s a simple flat monthly fee for each team member, with nothing to pay up front. You’re only charged for as long as they stay with you, which keeps your costs predictable and means the fee stops the moment they do.', link: { href: '#pricing', label: 'See pricing →' } },
  { q: 'What if it doesn’t work out?', a: 'If a match isn’t working out, we’ll step in and find you a replacement at no extra cost. And because you only ever pay while someone is actively on your team, you’re never left locked into a hire that isn’t pulling its weight.' },
  { q: 'How long until I meet candidates?', a: 'Usually, within a few weeks of our first call. We’d much rather take a little longer to test people properly than rush an unvetted name in front of you – but you certainly won’t be left waiting around for months.' },
  { q: 'What kinds of roles do you fill?', a: 'We focus on marketing, operations, customer success, strategy, and finance roles. Whatever the function, every person we place brings at least three years of real, hands-on experience – we don’t deal in juniors or jacks-of-all-trades.' },
];
---
<section class="tf" aria-label="Team and FAQ">
  <!-- Part A — the team -->
  <div class="tf-step" data-step>
    <p class="tf-eyebrow" data-anim data-delay="0">The people behind it</p>
    <h2 class="tf-h2" data-anim data-delay="80">You’ll be working with <em>us</em></h2>
    <p class="tf-intro" data-anim data-delay="160">Growthbuddy is a small, founder-led team, by design. When you call, you reach Avani or Srikant – the people who personally vouch for every match.</p>

    <div class="team">
      {team.map((m, i) => (
        <div class="member" data-anim data-delay={String(240 + i * 80)}>
          <div class="avatar" role="img" aria-label={`${m.name}, ${m.role}`}>{m.initial}</div>
          <div class="member-name">{m.name}</div>
          <div class="member-role">{m.role}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Part B — FAQ -->
  <div class="tf-step tf-faq" data-step>
    <p class="tf-eyebrow" data-anim data-delay="0">FAQ</p>
    <h2 class="tf-h2" data-anim data-delay="80">Commonly asked <em>questions</em></h2>
    <p class="tf-intro" data-anim data-delay="160">The things teams usually ask before they get started.</p>

    <div class="faq">
      {faqs.map((f, i) => (
        <details data-anim data-delay={String(240 + i * 80)} open={i === 0}>
          <summary>
            <span class="faq-q">{f.q}</span>
            <span class="faq-ic" data-ic aria-hidden="true"><span class="faq-bar faq-bar--h"></span><span class="faq-bar faq-bar--v"></span></span>
          </summary>
          <div class="faq-a">{f.a}{f.link && (<Fragment> <a class="faq-link" href={f.link.href}>{f.link.label}</a></Fragment>)}</div>
        </details>
      ))}
    </div>
  </div>
</section>

<noscript><style>[data-step],[data-anim]{opacity:1 !important;transform:none !important}</style></noscript>

<style>
  .tf{
    max-width:920px; margin:0 auto; padding:var(--gb-section-y) var(--gb-gutter); text-align:center;
    /* intrinsic-size matches the true rendered height so content-visibility
       reserves the right space and never shifts layout when it renders. */
    content-visibility:auto; contain-intrinsic-size:0 1960px;
  }

  /* step + sequenced children start hidden; the island reveals them */
  .tf-step{opacity:0; transform:translateY(16px); transition:opacity .6s var(--gb-ease), transform .6s var(--gb-ease)}
  .tf [data-anim]{opacity:0; transform:translateY(16px); transition:opacity .5s var(--gb-ease), transform .5s var(--gb-ease)}
  .tf-faq{margin-top:104px}

  .tf-eyebrow{
    margin:0 0 16px; font-family:var(--gb-font-label); font-weight:var(--gb-weight-eyebrow);
    text-transform:uppercase; letter-spacing:var(--gb-eyebrow-ls); font-size:var(--gb-fs-eyebrow); color:var(--gb-clay);
  }
  .tf-h2{
    margin:0 0 16px; font-family:var(--gb-font-display); font-weight:700; font-size:var(--gb-fs-title);
    line-height:1.1; letter-spacing:var(--gb-title-ls); color:var(--gb-ink);
  }
  .tf-h2 em{font-style:italic; font-weight:400; color:var(--gb-clay)}
  .tf-intro{
    margin:0 auto 56px; max-width:54ch; font-family:var(--gb-font-body); font-size:var(--gb-fs-lede);
    line-height:1.5; color:var(--gb-muted); text-wrap:pretty;
  }

  /* Team grid */
  .team{display:grid; grid-template-columns:repeat(3,1fr); gap:24px 22px; max-width:760px; margin:0 auto}
  .member{text-align:center}
  .avatar{
    width:100%; aspect-ratio:1/1; border-radius:var(--gb-radius-md);
    background:linear-gradient(150deg, #EFE2D2, #EADBCE);
    display:flex; align-items:center; justify-content:center;
    font-family:var(--gb-font-display); font-size:40px; color:var(--gb-clay-dark);
    box-shadow:0 1px 2px rgba(0,0,0,0.04), 0 10px 22px rgba(0,0,0,0.05);
  }
  .member-name{margin-top:14px; font-family:var(--gb-font-body); font-weight:var(--gb-weight-strong); font-size:17px; color:var(--gb-ink)}
  .member-role{margin-top:6px; font-family:var(--gb-font-label); text-transform:uppercase; letter-spacing:.05em; font-size:11px; color:var(--gb-clay)}

  /* FAQ */
  .faq{max-width:760px; margin:0 auto; text-align:left}
  .faq details{border-bottom:var(--gb-border-hairline)}
  .faq summary{
    display:flex; justify-content:space-between; align-items:center; gap:20px; cursor:pointer; padding:22px 0;
    font-family:var(--gb-font-body); font-weight:600; font-size:17px; color:var(--gb-ink); list-style:none;
  }
  .faq summary::-webkit-details-marker{display:none}
  .faq summary:focus-visible{outline:var(--gb-focus); outline-offset:3px}
  .faq-q{min-width:0}
  .faq-ic{flex:none; width:22px; height:22px; position:relative; transition:transform .3s var(--gb-ease)}
  .faq details[open] .faq-ic{transform:rotate(135deg)}
  .faq-bar{position:absolute; background:var(--gb-clay); border-radius:2px}
  .faq-bar--h{top:10px; left:3px; width:16px; height:2px}
  .faq-bar--v{top:3px; left:10px; width:2px; height:16px}
  .faq-a{padding:0 0 22px; margin-top:-4px; max-width:64ch; font-size:16px; line-height:1.6; color:var(--gb-muted)}
  .faq-link{color:var(--gb-clay); text-decoration:none; transition:color .15s ease}
  .faq-link:hover{color:var(--gb-clay-dark); text-decoration:underline}

  @media (max-width:768px){
    .tf{padding:72px 20px}
    .tf-h2{font-size:32px}
    .tf-intro{margin-bottom:40px}
    .tf-faq{margin-top:64px}
    .team{grid-template-columns:repeat(2,1fr); gap:18px}
    .avatar{font-size:34px}
  }
  @media (prefers-reduced-motion:reduce){
    .tf-step, .tf [data-anim]{opacity:1 !important; transform:none !important; transition:none !important}
    .faq-ic{transition:none !important}
  }
</style>

<script>
  // Sequenced steps (spec §7): per-step IO (0.3) → stagger [data-anim] by data-delay.
  const root = document.querySelector('.tf');
  if (root) {
    const steps = Array.from(root.querySelectorAll<HTMLElement>('[data-step]'));
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const fin = (el: HTMLElement) => { el.style.opacity = '1'; el.style.transform = 'none'; };
    const finalize = (s: HTMLElement) => { fin(s); s.querySelectorAll<HTMLElement>('[data-anim]').forEach(fin); };
    const animate = (s: HTMLElement) => {
      fin(s);
      s.querySelectorAll<HTMLElement>('[data-anim]').forEach((el) => {
        window.setTimeout(() => fin(el), parseInt(el.dataset.delay || '0', 10));
      });
    };

    if (reduced || !('IntersectionObserver' in window)) {
      steps.forEach(finalize);
    } else {
      steps.forEach((s) => {
        let done = false;
        let timer = 0;
        const go = (stagger: boolean) => {
          if (done) return; done = true;
          io.disconnect(); clearTimeout(timer);
          if (stagger && document.visibilityState === 'visible') animate(s); else finalize(s);
        };
        const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) go(true); }), { threshold: 0.3 });
        io.observe(s);
        timer = window.setTimeout(() => go(false), 2200); // safety net — never stuck hidden
      });
    }
  }
</script>
