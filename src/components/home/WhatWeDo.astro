---
/*
  Fold 2 — What we do / The Problem.
  Copy + structure from "Fold 2 – The Problem.html"; motion from
  INTERACTIVE-BEHAVIOUR-SPEC §2 (setupInk). No .dc.html present → spec authoritative.

  Scroll-ink: each [data-word] starts opacity:0.2 and inks to 1 as it rises through
  the viewport mid-line (start .85·vh → end .42·vh); [data-clay] words also lerp
  ink → clay channel-by-channel. reduced-motion / no-JS → all words opacity 1.
  Paper bg + the global .05 grain (no per-section grain).
*/
const lines = [
  ['Good', 'people', 'are', 'harder', 'to', 'find', 'than', 'ever.'],
  ['Local', 'salaries', 'keep', 'rising.', 'Searches', 'take', 'longer.'],
  ['And', 'after', 'all', 'the', 'interviews,', "you're", 'still', 'left', 'wondering', 'if', 'they', 'can', 'actually', 'do', 'the', 'work.'],
];
const clayLine = ['We', 'built', 'Growthbuddy', 'to', 'solve', 'all', 'of', 'this.'];

const builtFor = [
  { label: 'Agencies', tint: 'sage' },
  { label: 'Startups', tint: 'wheat' },
  { label: 'Consulting firms', tint: 'clay' },
  { label: '10–150 employees', tint: 'olive' },
  { label: 'Marketing teams', tint: 'rose' },
  { label: 'Operations teams', tint: 'teal' },
  { label: 'Finance teams', tint: 'sand' },
];
---
<section class="whatwedo" aria-label="The problem we solve">
  <div class="ww-inner">
    <div class="ink-stmt" data-ink>
      {lines.map((words) => (
        <p class="stmt">{words.map((w) => (<span class="word" data-word>{w + ' '}</span>))}</p>
      ))}
      <p class="stmt clay-line">{clayLine.map((w) => (<span class="word" data-word data-clay>{w + ' '}</span>))}</p>
    </div>

    <div class="built-for" data-reveal>
      <p class="built-for-label">Built for</p>
      <div class="pills">
        {builtFor.map((p) => (<span class={`cat-pill tint-${p.tint}`}>{p.label}</span>))}
      </div>
    </div>
  </div>
</section>

<noscript>
  <style>.word{opacity:1 !important} .word[data-clay]{color:var(--gb-clay) !important}</style>
</noscript>

<style>
  .whatwedo{padding:clamp(84px, 10vw, 120px) 0}
  .ww-inner{max-width:860px; margin:0 auto; padding:0 32px}

  .stmt{
    margin:0 0 .5em; font-family:var(--gb-font-display); font-weight:400;
    font-size:var(--gb-fs-statement); line-height:1.46; letter-spacing:var(--gb-display-ls); text-align:left;
  }
  .clay-line{margin-bottom:0}
  /* Resting state per spec §2: dim ink; the island inks each word on scroll. */
  .word{color:var(--gb-ink); opacity:.2}

  @media (prefers-reduced-motion:reduce){
    .word{opacity:1}
    .word[data-clay]{color:var(--gb-clay)}
  }

  .built-for{margin-top:56px; display:flex; align-items:flex-start; gap:40px}
  .built-for-label{
    flex:none; margin:0; padding-top:9px; font-family:var(--gb-font-label);
    font-weight:var(--gb-weight-eyebrow); text-transform:uppercase; letter-spacing:.14em;
    font-size:14px; color:var(--gb-clay);
  }
  .pills{flex:1; display:flex; flex-wrap:wrap; gap:10px}
  .cat-pill{
    display:inline-flex; align-items:center; white-space:nowrap;
    font-family:var(--gb-font-body); font-weight:500; font-size:14.5px;
    padding:9px 18px; border-radius:var(--gb-radius-pill);
  }
  .tint-sage{background:var(--gb-tint-sage-bg); color:var(--gb-tint-sage-tx)}
  .tint-wheat{background:var(--gb-tint-wheat-bg); color:var(--gb-tint-wheat-tx)}
  .tint-clay{background:var(--gb-tint-clay-bg); color:var(--gb-tint-clay-tx)}
  .tint-olive{background:var(--gb-tint-olive-bg); color:var(--gb-tint-olive-tx)}
  .tint-rose{background:var(--gb-tint-rose-bg); color:var(--gb-tint-rose-tx)}
  .tint-teal{background:var(--gb-tint-teal-bg); color:var(--gb-tint-teal-tx)}
  .tint-sand{background:var(--gb-tint-sand-bg); color:var(--gb-tint-sand-tx)}

  @media (max-width:768px){
    .ww-inner{padding:0 20px}
    .built-for{margin-top:44px}
  }
  @media (max-width:560px){
    .built-for{flex-direction:column; gap:14px}
    .built-for-label{padding-top:0}
  }
</style>

<script>
  /*
    Scroll-ink (INTERACTIVE-BEHAVIOUR-SPEC §2; CLAUDE.md performance budget).
    Word document-relative centres are measured ONCE (mount / resize / fonts /
    load) and cached — the rAF scroll loop reads no layout, only window.scrollY:
      c = cachedCentre − scrollY; p = clamp01((0.85·vh − c)/(0.85·vh − 0.42·vh));
      opacity = 0.2 + 0.8·p. data-clay words also lerp ink → clay (= --gb-ink /
    --gb-clay). reduced-motion: jump to final state (opacity 1, clay words clay).
  */
  const initInk = () => {
    const root = document.querySelector('[data-ink]');
    if (!root) return;
    const words = Array.from(root.querySelectorAll<HTMLElement>('[data-word]'));
    if (words.length === 0) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      words.forEach((w) => { w.style.opacity = '1'; if (w.hasAttribute('data-clay')) w.style.color = 'rgb(185,107,77)'; });
      return;
    }

    const INK = [24, 26, 31], CLAY = [185, 107, 77]; // = --gb-ink / --gb-clay
    const isClay = words.map((w) => w.hasAttribute('data-clay'));
    let centres: number[] = [];

    // The ONLY layout reads — once on load + resize, never in the scroll loop.
    const measure = () => {
      const sy = window.scrollY;
      centres = words.map((w) => { const r = w.getBoundingClientRect(); return r.top + sy + r.height / 2; });
    };

    let ticking = false;
    const update = () => {
      ticking = false;
      const vh = window.innerHeight;
      const start = vh * 0.85, span = start - vh * 0.42;
      const sy = window.scrollY;
      for (let i = 0; i < words.length; i++) {
        const c = centres[i] - sy; // viewport centre from cache — no DOM read
        let p = (start - c) / span;
        p = p < 0 ? 0 : p > 1 ? 1 : p;
        const w = words[i];
        w.style.opacity = String(0.2 + 0.8 * p);
        if (isClay[i]) {
          const mix = (a: number, b: number) => Math.round(a + (b - a) * p);
          w.style.color = `rgb(${mix(INK[0], CLAY[0])},${mix(INK[1], CLAY[1])},${mix(INK[2], CLAY[2])})`;
        }
      }
    };
    const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } };
    const remeasure = () => { measure(); onScroll(); };

    measure();
    update(); // run once on mount
    addEventListener('scroll', onScroll, { passive: true });
    addEventListener('resize', remeasure, { passive: true });
    // Layout can shift after fonts / late images load — recache then.
    addEventListener('load', remeasure, { once: true });
    if (document.fonts && document.fonts.ready) document.fonts.ready.then(remeasure);
  };

  if (document.readyState !== 'loading') initInk();
  else addEventListener('DOMContentLoaded', initInk);
</script>
