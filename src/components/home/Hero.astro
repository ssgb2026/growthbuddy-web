---
/*
  Fold 1 — Hero (reproduces "Fold 1 – Hero.html").
  Holds the page's single <h1>. The gold halo + grain live only here.

  Token reconciliations vs the mock:
  - Gold halo uses the --gb-gold-* ramp; H1 ink --gb-ink-hero, sub --gb-sub-hero,
    bullets --gb-bullet-hero; the one italic word is --gb-clay-dark (the mock's
    hero em is #9E5740, darker than body-heading clay, for legibility on gold).
  - CTA = locked neumorphic on-gold pill driven by the --gb-cta-* tokens.
  - Grain: mix-blend overlay, opacity .18 (design review dialled the mock's
    heavy .65 down to a subtle texture).
  - .hero is raised above the global paper-grain (z-index:2) so only its own
    overlay grain textures the gold; paper sections keep the .gb-grain layer.

  Face panels: 14 real, consented photos (extracted from the mock into
  /img/hero-faces/), grayscale per the mock. The grid is a single role="img".
*/
import Cta from '../Cta.astro';
let _i = 0;
const faceRows = [
  ['01', '02', '03', '04'],
  ['05', '06', '07', '08', '09', '10'],
  ['11', '12', '13', '14'],
].map((row) => row.map((n) => ({ n, i: _i++ }))); // i = data-i (0..13); focus tile is i=7
---
<section class="hero" data-screen-label="Hero" aria-label="Hire sharper talent without hiring locally">
  <div class="inner">
    <div class="panels" role="img" aria-label="People Growthbuddy has hired and coached" data-reveal data-delay="80">
      {faceRows.map((row) => (
        <div class="prow">
          {row.map((tile) => (
            <div class="panel" data-i={tile.i} style={`background-image:url(/img/hero-faces/face-${tile.n}.webp)`}></div>
          ))}
        </div>
      ))}
    </div>

    <h1 class="h1" data-reveal data-delay="160">Hire <em>sharper</em> talent without hiring locally.</h1>

    <p class="sub" data-reveal data-delay="240">We find highly capable people globally, vet them deeply and manage their performance after they join your team.</p>

    <div class="hero-cta" data-reveal data-delay="320">
      <Cta variant="gold" label="Start hiring" href="/book-a-call" />
    </div>

    <div class="bullets" data-reveal data-delay="400">
      <span>
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 17 13.5 8.5 9 13 2 6.5"></polyline><polyline points="16.5 17 22 17 22 11.5"></polyline></svg>
        60% lower salary costs
      </span>
      <span>
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="13" cy="12" r="9"></circle><polyline points="13 7 13 12 16.5 14"></polyline></svg>
        Aligned to your hours
      </span>
      <span>
        <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7.5 4h10v5a5 5 0 0 1-10 0V4z"></path><path d="M7.5 5.5H5a2 2 0 0 0 0 5H7.5"></path><path d="M17.5 5.5h2.5a2 2 0 0 1 0 5H17.5"></path><line x1="12.5" y1="14" x2="12.5" y2="17.5"></line><line x1="8.9" y1="20.5" x2="16.1" y2="20.5"></line></svg>
        Personally coached to perform
      </span>
    </div>
  </div>
</section>

<style>
  .hero{
    position:relative; z-index:2; flex:1 1 auto; min-height:520px; display:flex; overflow:hidden;
    border-radius:0 0 40px 40px;
    background:
      radial-gradient(60% 50% at 50% 16%, var(--gb-gold-hi) 0%, rgba(243,222,160,0) 62%),
      radial-gradient(80% 75% at 20% 28%, var(--gb-gold-warm) 0%, rgba(232,195,135,0) 58%),
      radial-gradient(95% 95% at 82% 90%, var(--gb-gold-deep) 0%, rgba(169,118,47,0) 60%),
      radial-gradient(130% 120% at 50% 42%, var(--gb-gold) 0%, var(--gb-gold-mid) 52%, var(--gb-gold-shadow) 100%);
  }
  /* Hero grain — static tiling noise PNG, no mix-blend-mode (a blended overlay
     forces the hero off the fast-composite path and janks on scroll). .14 reads
     close to the old .18 overlay without the blend's graying. */
  .hero::after{
    content:""; position:absolute; inset:0; pointer-events:none; opacity:.14;
    background-image:url("/img/grain.png"); background-size:128px 128px; background-repeat:repeat;
  }

  .inner{
    position:relative; z-index:2; flex:1; display:flex; flex-direction:column;
    align-items:center; justify-content:center; text-align:center; padding:96px 32px 44px;
  }

  /* Face cluster — photos are baked greyscale (no runtime filter). The magnifier
     animates ONLY transform/opacity (+ the glow pseudo's opacity); never blur or
     box-shadow per frame. border-radius clips the bg, so no overflow:hidden — the
     glow pseudo must not be clipped. */
  .panels{position:relative; display:flex; flex-direction:column; align-items:center; gap:15px; margin:0 0 44px}
  .prow{display:flex; justify-content:center; gap:15px}
  .panel{
    position:relative; width:58px; height:58px; border-radius:15px;
    background-color:#EFE2D2; background-size:cover; background-position:center 38%; background-repeat:no-repeat;
    box-shadow:var(--gb-shadow-tile);
    transition:transform .26s ease-out, opacity .26s ease-out;
  }
  /* Focus glow: static max shadow, faded by --sf (= f) — opacity only, no paint. */
  .panel::after{
    content:""; position:absolute; inset:0; border-radius:inherit; pointer-events:none;
    box-shadow:0 10px 26px rgba(40,26,12,.30); opacity:var(--sf, 0);
    transition:opacity .26s ease-out;
  }

  .h1{
    font-family:var(--gb-font-display); font-weight:700; font-size:var(--gb-fs-display);
    line-height:1.08; letter-spacing:var(--gb-display-ls); color:var(--gb-ink-hero);
    max-width:16ch; margin:0; text-wrap:balance;
  }
  .h1 em{font-style:italic; font-weight:400; color:var(--gb-clay-dark)}

  .sub{
    font-family:var(--gb-font-body); font-size:var(--gb-fs-lede); line-height:1.4;
    color:var(--gb-sub-hero); max-width:50ch; margin:28px 0 0; font-weight:500; text-wrap:pretty;
  }

  .bullets{display:flex; flex-wrap:wrap; justify-content:center; gap:14px 20px; margin:36px 0 0}
  .bullets span{
    display:inline-flex; align-items:center; gap:8px; font-family:var(--gb-font-label);
    text-transform:uppercase; letter-spacing:.04em; font-size:12px; font-weight:500; color:var(--gb-bullet-hero);
  }
  .bullets svg{stroke:var(--gb-clay-dark); flex:none}

  /* Primary CTA — the locked neumorphic pill is the shared <Cta variant="gold">. */
  .hero-cta{margin-top:28px}

  /* Short-viewport + mobile rhythm (from the mock). */
  @media (max-height:870px){
    .inner{padding:84px 32px 34px}
    .panels{gap:13px; margin:0 0 34px} .prow{gap:13px}
    .panel{width:52px; height:52px; border-radius:13px}
    .sub{margin-top:22px} .bullets{margin-top:30px} .hero-cta{margin-top:22px}
  }
  @media (max-height:760px){
    .inner{padding:78px 32px 26px}
    .panels{gap:11px; margin:0 0 26px} .prow{gap:11px}
    .panel{width:46px; height:46px; border-radius:12px}
    .h1{font-size:clamp(34px,4.6vw,52px)}
    .sub{margin-top:18px} .bullets{margin-top:26px} .hero-cta{margin-top:18px}
  }
  @media (max-width:768px){
    .hero{border-radius:0 0 var(--gb-radius-2xl) var(--gb-radius-2xl); min-height:auto}
    .inner{padding:100px 22px 48px}
    .panels{gap:9px; margin:0 0 30px} .prow{gap:9px}
    .panel{width:42px; height:42px; border-radius:11px}
  }
</style>

<script>
  /*
    Hero face-grid — Gaussian "magnifier" focus (no pixel warp; each fixed-size
    tile is re-styled by its distance to a focus point).

    Focus point: the cursor while over the cluster; tile i=7 (just right of
    centre) when idle / on leave. Per tile f = exp(-d² / (2·SIG²)), SIG ≈ half
    the cluster's corner-distance. f drives scale / opacity / blur / shadow /
    z-index. rAF-throttled; centres measured (transforms cleared) on load,
    resize and pointer-enter. prefers-reduced-motion: static resting focus only.
  */
  const initFocusGrid = () => {
    const panels = document.querySelector('.panels');
    if (!(panels instanceof HTMLElement)) return;
    const tiles = Array.from(panels.querySelectorAll<HTMLElement>('.panel'));
    if (tiles.length === 0) return;

    const FI = 7;                                   // resting focus tile (data-i=7)
    const SCALE_MIN = 0.66, SCALE_SPAN = 0.60;      // scale = 0.66 → 1.26
    const OP_MIN = 0.18, OP_SPAN = 0.82;            // opacity = 0.18 → 1.0

    let centers: { x: number; y: number }[] = [];
    let SIG = 112, fx0 = 0, fy0 = 0;
    let raf = 0, px = 0, py = 0, hovering = false;

    const measure = () => {
      tiles.forEach((t) => { t.style.transform = ''; });   // clear before reading layout
      void panels.offsetWidth;                             // force reflow
      centers = tiles.map((t) => {
        const r = t.getBoundingClientRect();
        return { x: r.left + r.width / 2, y: r.top + r.height / 2 };
      });
      const cr = panels.getBoundingClientRect();
      SIG = Math.hypot(cr.width, cr.height) / 4 || 112;     // ≈ half the corner-distance
      fx0 = centers[FI].x; fy0 = centers[FI].y;
    };

    const apply = (fx: number, fy: number) => {
      const denom = 2 * SIG * SIG;
      for (let i = 0; i < tiles.length; i++) {
        const c = centers[i];
        const dx = c.x - fx, dy = c.y - fy;
        const f = Math.exp(-(dx * dx + dy * dy) / denom);
        const t = tiles[i];
        // transform + opacity only; the glow is the pseudo's opacity via --sf.
        t.style.transform = `scale(${(SCALE_MIN + SCALE_SPAN * f).toFixed(3)})`;
        t.style.opacity = (OP_MIN + OP_SPAN * f).toFixed(3);
        t.style.setProperty('--sf', f.toFixed(3));
        t.style.zIndex = String(Math.round(20 * f));
      }
    };

    // Promote tiles to their own layers ONLY while interacting, then release.
    let release = 0;
    const promote = (on: boolean) => { const v = on ? 'transform' : 'auto'; for (const t of tiles) t.style.willChange = v; };

    const frame = () => { raf = 0; apply(px, py); };
    const onMove = (e: PointerEvent) => { px = e.clientX; py = e.clientY; if (!raf) raf = requestAnimationFrame(frame); };
    const onEnter = (e: PointerEvent) => { hovering = true; clearTimeout(release); promote(true); measure(); px = e.clientX; py = e.clientY; if (!raf) raf = requestAnimationFrame(frame); };
    const onLeave = () => { hovering = false; if (raf) { cancelAnimationFrame(raf); raf = 0; } apply(fx0, fy0); release = window.setTimeout(() => promote(false), 320); };

    measure();
    apply(fx0, fy0);                                 // resting focus on load

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce) {
      panels.addEventListener('pointerenter', onEnter);
      panels.addEventListener('pointermove', onMove);
      panels.addEventListener('pointerleave', onLeave);
    }
    window.addEventListener('resize', () => { measure(); if (!hovering) apply(fx0, fy0); }, { passive: true });
  };

  // Measure after layout settles (the cluster fades/translates in on reveal).
  if (document.readyState === 'complete') requestAnimationFrame(initFocusGrid);
  else window.addEventListener('load', () => requestAnimationFrame(initFocusGrid));
</script>
